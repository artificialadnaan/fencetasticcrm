# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/fencetastic?schema=public"

# Auth
JWT_SECRET="change-me-to-a-random-64-char-string"

# Frontend URL(s) for CORS — comma-separated for multiple origins
# Dev: http://localhost:5173
# Prod: https://app.fencetastic.app
FRONTEND_URL="http://localhost:5173"

# API Port
PORT=3001

# Node environment
NODE_ENV=development

# Cloudflare R2 (photo storage)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=

# --- Web app (.env in apps/web/) ---
# VITE_API_URL=http://localhost:3001
# VITE_DEV_PASSWORD=Fencetastic2024!
